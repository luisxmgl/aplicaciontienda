<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvAdminOrderCode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pedido #1234"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/brand_azul" />

            <TextView
                android:id="@+id/tvAdminOrderDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hace 2 min"
                android:textSize="12sp"
                android:textColor="#888888" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAdminOrderDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Detalle de productos..."
            android:textColor="#444444" />

        <TextView
            android:id="@+id/tvAdminOrderCustomization"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Personalización: Ninguna"
            android:textColor="#D32F2F"
            android:textStyle="italic" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginVertical="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cambiar Estado:"
            android:textSize="14sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/rbStatus1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Recibido"
                android:textSize="12sp" />

            <RadioButton
                android:id="@+id/rbStatus2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Taller"
                android:textSize="12sp" />

            <RadioButton
                android:id="@+id/rbStatus3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Listo"
                android:textSize="12sp" />

            <RadioButton
                android:id="@+id/rbStatus4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Entregado"
                android:textSize="12sp" />
        </RadioGroup>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
