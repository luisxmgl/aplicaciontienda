<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <!-- Custom Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:rotation="180"
            android:scaleX="-1"
            android:src="?attr/homeAsUpIndicator"
            app:tint="@color/neutral_charcoal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sobre nosotros"
            android:textColor="@color/neutral_charcoal"
            android:textSize="20sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/viewPagerSlideshow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="500dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Confecciones Villa Acero"
                android:textColor="#162A42"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="296dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Tienda de uniformes en Hualpén."
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contacto"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWhatsApp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="2dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="WhatsApp\n+56920680021"
                android:textAllCaps="false"
                app:backgroundTint="@color/verde_whatsapp"
                app:cornerRadius="12dp"
                app:icon="@drawable/whatsappicono"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconSize="32dp"
                app:iconTint="@null" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInstagram"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="#F5F5F5"
                android:lineSpacingExtra="2dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Instagram\n@confecciones.villaacero"
                android:textAllCaps="false"
                android:textColor="@color/neutral_charcoal"
                app:cornerRadius="12dp"
                app:strokeColor="#DDDDDD"
                app:strokeWidth="1dp"
                app:icon="@drawable/instagramicono"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconSize="32dp"
                app:iconTint="@null" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMaps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="#FFFFFF"
                android:lineSpacingExtra="2dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Cómo llegar\nLos Poetas 8741, Hualpén"
                android:textAllCaps="false"
                android:textColor="@color/neutral_charcoal"
                app:cornerRadius="12dp"
                app:strokeColor="#DDDDDD"
                app:strokeWidth="1dp"
                app:icon="@drawable/gpsicono"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconSize="32dp"
                app:iconTint="@null" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:strokeColor="#EEEEEE"
                app:strokeWidth="1dp"
                app:cardElevation="0dp"
                android:layout_marginTop="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Colegios atendidos"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvColegios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:text="App Confecciones Villa Acero"
                android:textColor="#888888"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>